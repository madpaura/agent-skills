# ============================================================================
# Claude Code Environment - Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ---- Anthropic API Key (REQUIRED for Claude Code CLI) ----
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ---- code-server Authentication ----
# Password for the VS Code web UI (default: claude-dev)
CODE_SERVER_PASSWORD=claude-dev
# Set to "none" to disable authentication (not recommended for remote access)
# CODE_SERVER_AUTH=none

# ---- Git Configuration (optional) ----
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL="your.email@example.com"

# ---- Workspace Path ----
# Path on your host machine to mount as the workspace
WORKSPACE_PATH=./workspace

# ---- Timezone ----
TZ=Asia/Kolkata

# ---- Network Mode (used by run.sh) ----
# "host" = full host network access (all ports directly exposed)
# "bridge" = isolated networking with port mapping
NETWORK_MODE=host

# ---- VS Code Port (only used when NETWORK_MODE=bridge) ----
VSCODE_PORT=8080

# ---- Resource Limits ----
MEMORY_LIMIT=8g
CPU_LIMIT=4.0

# ---- Optional Mounts (set to "true" to enable) ----
MOUNT_DOCKER_SOCKET=false
MOUNT_SSH_KEYS=false
MOUNT_GITCONFIG=true
