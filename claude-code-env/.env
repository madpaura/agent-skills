# ============================================================================
# Claude Code Environment - Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ---- Anthropic API Key (REQUIRED for Claude Code CLI) ----
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ---- code-server Authentication ----
# Password for the VS Code web UI (default: claude-dev)
CODE_SERVER_PASSWORD=claude-dev
# Set to "none" to disable authentication (not recommended for remote access)
# CODE_SERVER_AUTH=none

# ---- Git Configuration (optional) ----
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your.email@example.com

# ---- Workspace Path ----
# Path on your host machine to mount as the workspace
WORKSPACE_PATH=./workspace

# ---- Timezone ----
TZ=Asia/Kolkata
